{
  "manifest_version": 3,
  "name": "Verdiqt",
  "version": "1.0.0",
  "description": "AI powered review analyzer",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.amazon.in/*",
    "https://www.amazon.com/*",
    "https://www.flipkart.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.in/*",
        "https://www.amazon.com/*",
        "https://www.flipkart.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.css", "sidebar.js"],
      "matches": [
        "https://www.amazon.in/*",
        "https://www.amazon.com/*",
        "https://www.flipkart.com/*"
      ]
    }
  ]
}